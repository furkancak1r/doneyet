{
  "expo": {
    "name": "DoneYet?",
    "slug": "doneyet",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F0E8"
    },
    "scheme": "doneyet",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "ios": {
      "bundleIdentifier": "com.doneyet.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.furkancakir.doneyet",
      "allowBackup": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1F5C52"
      }
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "1e54e95d-a6ea-4673-b02b-57ae718bc7aa"
      }
    },
    "owner": "mxa123"
  }
}
