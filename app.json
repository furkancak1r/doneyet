{
  "expo": {
    "name": "DoneYet?",
    "slug": "doneyet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpeg",
    "splash": {
      "image": "./assets/icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#F4F0E8"
    },
    "scheme": "doneyet",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "jsEngine": "hermes",
    "ios": {
      "bundleIdentifier": "com.doneyet.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.doneyet.app",
      "allowBackup": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpeg",
        "backgroundColor": "#1F5C52"
      }
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
